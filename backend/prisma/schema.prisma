generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Profissional {
  id           String               @id @default(uuid())
  nome         String
  telefone     String?
  email        String?
  comissao     Float                @default(40)
  ativo        Boolean              @default(true)
  createdAt    DateTime             @default(now())
  servicos     ProfissionalServico[]
  agendamentos Agendamento[]
}

model Servico {
  id            String               @id @default(uuid())
  nome          String
  preco         Float
  duracaoMin    Int
  descricao     String?
  ativo         Boolean              @default(true)
  createdAt     DateTime             @default(now())
  profissionais ProfissionalServico[]
  agendamentos  Agendamento[]
}

model ProfissionalServico {
  profissional   Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  profissionalId String
  servico        Servico      @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  servicoId      String

  @@id([profissionalId, servicoId])
}

model Cliente {
  id           String        @id @default(uuid())
  nome         String
  telefone     String
  email        String?
  dataNasc     DateTime?
  observacoes  String?
  createdAt    DateTime      @default(now())
  agendamentos Agendamento[]
}

model Agendamento {
  id             String           @id @default(uuid())
  cliente        Cliente          @relation(fields: [clienteId], references: [id])
  clienteId      String
  profissional   Profissional     @relation(fields: [profissionalId], references: [id])
  profissionalId String
  servico        Servico          @relation(fields: [servicoId], references: [id])
  servicoId      String
  dataHora       DateTime
  status         String           @default("agendado")
  observacoes    String?
  createdAt      DateTime         @default(now())
  lancamento     LancamentoCaixa?
}

model LancamentoCaixa {
  id             String       @id @default(uuid())
  agendamento    Agendamento? @relation(fields: [agendamentoId], references: [id])
  agendamentoId  String?      @unique
  tipo           String
  descricao      String
  valor          Float
  formaPagamento String?
  data           DateTime     @default(now())
  createdAt      DateTime     @default(now())
}

model Produto {
  id              String                @id @default(uuid())
  nome            String
  categoria       String?
  quantidadeAtual Float
  quantidadeMin   Float
  unidade         String
  preco           Float?
  ativo           Boolean               @default(true)
  createdAt       DateTime              @default(now())
  movimentacoes   MovimentacaoEstoque[]
}

model MovimentacaoEstoque {
  id        String   @id @default(uuid())
  produto   Produto  @relation(fields: [produtoId], references: [id])
  produtoId String
  tipo      String
  quantidade Float
  obs       String?
  data      DateTime @default(now())
}
